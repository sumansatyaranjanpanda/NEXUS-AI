# === LLM (OpenRouter — OpenAI-compatible gateway) ===
# Rotate keys at https://openrouter.ai/keys — never commit real keys
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Web Search (Tavily) ===
# Get a free key at https://tavily.com — enables real web search in the research agent
# Without this key, research agent falls back to LLM-only generation (hallucinated findings)
TAVILY_API_KEY=tvly-xxxx

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nexus_kb

# === Redis ===
# Use redis-stack image (not plain redis:alpine) for Redis checkpointer + Celery to work
REDIS_URL=redis://localhost:6379/0

# === Cohere ===
COHERE_API_KEY=xxxx

# === RAG ===
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SPARSE_MODEL="prithivida/Splade_PP_en_v1"
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5

# === Tracing & Evaluation (Langfuse) ===
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# === App ===
LOG_LEVEL=INFO
APP_ENV=development
